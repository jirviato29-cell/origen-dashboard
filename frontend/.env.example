# Copia a .env.local (ignorado por git) para desarrollo.
VITE_API_URL=http://localhost:3001/api
VITE_USE_MOCK=false

# Clave PÚBLICA VAPID para notificaciones push (la MISMA que VAPID_PUBLIC_KEY del
# backend). En producción se configura en Vercel como variable de entorno; NO se
# commitea el valor real. Genera el par con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
